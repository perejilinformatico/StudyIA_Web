---
import '../styles/boton_caricaturesco.css';
---

<section class="demo-section" id="demo">
  <div class="demo-bg">
    <div class="demo-blob db1"></div>
    <div class="demo-blob db2"></div>
  </div>
  
  <div class="demo-container">
    <div class="demo-left">
      <span class="demo-badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        Demo Lista
      </span>
      
      <h2 class="demo-title">
        StudyIA ya está <span class="title-gradient">disponible</span>
      </h2>
      
      <p class="demo-description">
        StudyIA ya está lista para vos. Probá ahora nuestra demo interactiva y descubrí cómo la inteligencia artificial puede transformar tu forma de estudiar.
      </p>
      
      <div class="demo-features">
        <div class="feature-item">
          <div class="feature-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span>Respuestas instantáneas a cualquier pregunta</span>
        </div>
        <div class="feature-item">
          <div class="feature-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span>Explicaciones personalizadas para vos</span>
        </div>
        <div class="feature-item">
          <div class="feature-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span>Generación de ejercicios y resúmenes</span>
        </div>
        <div class="feature-item">
          <div class="feature-check">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </div>
          <span>Disponible 24/7 desde cualquier dispositivo</span>
        </div>
      </div>
    </div>
    
    <div class="demo-right">
      <div class="phone-mockup">
        <div class="phone-notch"></div>
        <div class="phone-screen">
          <div class="chat-bubble bot">
            <span class="chat-text">¡Hola! ¿En qué puedo ayudarte hoy?</span>
          </div>
          <div class="chat-bubble user">
            <span class="chat-text">¿Qué es la fotosíntesis?</span>
          </div>
          <div class="chat-bubble bot typing">
            <span class="typing-dots">
              <span></span><span></span><span></span>
            </span>
          </div>
          <div class="chat-bubble bot response">
            <span class="chat-text">La fotosíntesis es el proceso por el cual las plantas convierten luz solar en energía...</span>
          </div>
        </div>
      </div>
      
      <div class="countdown-wrapper">
        <a href="http://localhost:3000" target="_blank" class="boton boton-rojo demo-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
          Probar Demo
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap');
  
  .demo-section {
    position: relative;
    padding: 100px 20px;
    overflow: hidden;
    background: linear-gradient(180deg, #fff 0%, #fff5f5 50%, #fff 100%);
  }
  
  .demo-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  
  .demo-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.5;
  }
  
  .db1 {
    width: 400px;
    height: 400px;
    background: rgba(216, 64, 64, 0.2);
    top: 10%;
    left: -100px;
  }
  
  .db2 {
    width: 350px;
    height: 350px;
    background: rgba(255, 183, 77, 0.15);
    bottom: 10%;
    right: -50px;
  }
  
  .demo-container {
    position: relative;
    z-index: 2;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  
  .demo-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  
  .demo-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background: rgba(216, 64, 64, 0.08);
    border: 1px solid rgba(216, 64, 64, 0.15);
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 600;
    color: #D84040;
    margin-bottom: 20px;
  }
  
  .demo-title {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #2B2A2A;
    margin: 0 0 20px 0;
    line-height: 1.2;
  }
  
  .title-gradient {
    background: linear-gradient(135deg, #D84040, #FF6B6B);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .demo-description {
    font-size: 1.1rem;
    color: #525252;
    line-height: 1.7;
    margin: 0 0 28px 0;
  }
  
  .demo-features {
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 36px;
  }
  
  .feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: #404040;
  }
  
  .feature-check {
    width: 24px;
    height: 24px;
    background: linear-gradient(135deg, #D84040, #FF6B6B);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
  }
  
  .demo-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
  
  .boton-outline-wa {
    position: relative;
    padding: 14px 32px;
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
    border-radius: 16px;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    outline: none;
    font-family: 'Segoe UI', sans-serif;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #25D366;
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
  }
  
  .boton-outline-wa:hover {
    background: #20BD5A;
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(37, 211, 102, 0.3);
  }
  
  .demo-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }
  
  .phone-mockup {
    width: 280px;
    height: 420px;
    background: #1a1a1a;
    border-radius: 36px;
    padding: 12px;
    box-shadow: 0 25px 80px rgba(0, 0, 0, 0.2), inset 0 0 0 2px #333;
    position: relative;
  }
  
  .phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: #1a1a1a;
    border-radius: 0 0 18px 18px;
    z-index: 3;
  }
  
  .phone-screen {
    background: #0a0a0a;
    border-radius: 28px;
    height: 100%;
    padding: 50px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    overflow: hidden;
  }
  
  .chat-bubble {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 16px;
    font-size: 0.8rem;
    line-height: 1.4;
    animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .chat-bubble.bot {
    background: #252525;
    color: #e5e5e5;
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  
  .chat-bubble.user {
    background: linear-gradient(135deg, #D84040, #FF6B6B);
    color: white;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  
  .chat-bubble.typing {
    background: #252525;
    padding: 14px 18px;
  }
  
  .typing-dots {
    display: flex;
    gap: 4px;
    align-items: center;
  }
  
  .typing-dots span {
    width: 6px;
    height: 6px;
    background: #666;
    border-radius: 50%;
    animation: typingBounce 1.4s ease-in-out infinite;
  }
  
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  
  .chat-bubble.response {
    animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) 2s both;
  }
  
  @keyframes typingBounce {
    0%, 60%, 100% { transform: translateY(0); background: #666; }
    30% { transform: translateY(-6px); background: #999; }
  }
  
  @keyframes popIn {
    from { opacity: 0; transform: scale(0.8) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
  
  .countdown-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 20px 28px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 20px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
  }

  .demo-link {
    padding: 14px 32px;
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
    border-radius: 16px;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    outline: none;
    font-family: 'Segoe UI', sans-serif;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(216, 64, 64, 0.3);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #D84040, #FF6B6B);
    color: white;
  }

  .demo-link:hover {
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 8px 25px rgba(216, 64, 64, 0.4);
  }

  .demo-link:active {
    transform: translateY(-2px) scale(1.02);
  }
  
  @media (max-width: 900px) {
    .demo-container {
      grid-template-columns: 1fr;
      gap: 50px;
    }
    
    .demo-left {
      align-items: center;
      text-align: center;
    }
    
    .demo-right {
      display: none;
    }
  }
  
  @media (max-width: 480px) {
    .demo-section {
      padding: 60px 16px;
    }
    
    .demo-actions {
      flex-direction: column;
      width: 100%;
    }
    
    .demo-actions .boton {
      width: 100%;
      justify-content: center;
    }
  }
</style>

