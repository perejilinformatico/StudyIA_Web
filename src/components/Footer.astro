<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap');
  
  .site-footer {
    background: #1a1a1a;
    color: #a3a3a3;
    font-family: "Plus Jakarta Sans", sans-serif;
  }
  
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 24px 30px;
  }
  
  .footer-top {
    display: grid;
    grid-template-columns: 1.5fr 2fr;
    gap: 60px;
    margin-bottom: 50px;
  }
  
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: white;
    font-size: 1.3rem;
    font-weight: 800;
    margin-bottom: 16px;
  }
  
  .footer-logo img {
    border-radius: 12px;
    box-shadow: 0 6px 14px rgba(216, 64, 64, 0.2);
  }
  
  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #737373;
    margin: 0 0 24px 0;
  }
  
  .footer-social {
    display: flex;
    gap: 12px;
  }
  
  .social-link {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #a3a3a3;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .social-link:hover {
    background: #25D366;
    border-color: #25D366;
    color: white;
    transform: translateY(-3px);
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }
  
  .footer-column h4 {
    color: white;
    font-size: 0.9rem;
    font-weight: 700;
    margin: 0 0 18px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  
  .footer-column ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .footer-column a {
    color: #737373;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s ease;
  }
  
  .footer-column a:hover {
    color: #D84040;
  }
  
  .footer-bottom {
    margin-top: 10px;
  }
  
  .footer-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin-bottom: 24px;
  }
  
  .footer-bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }
  
  .footer-bottom-content p {
    font-size: 0.85rem;
    margin: 0;
    color: #525252;
  }
  
  .footer-credit a {
    color: #D84040;
    text-decoration: none;
    font-weight: 600;
    transition: color 0.3s ease;
  }
  
  .footer-credit a:hover {
    color: #FF6B6B;
  }
  
  @media (max-width: 900px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    
    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 560px) {
    .footer-container {
      padding: 40px 16px 24px;
    }
    
    .footer-links {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    
    .footer-bottom-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>