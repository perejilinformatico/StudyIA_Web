---
 import '../styles/boton_caricaturesco.css';
---
<div id="inicio" class="flex flex-col items-center justify-center text-center gap-3.5 z-20">
    <h1 class="text-4xl">StudyIA</h1>
    <p class="w-2/3 m-3 font-normal">¡Bienvenidos a StudyIA! <br> Tu asistente de aprendizaje de inteligencia artificial</p>
    <img src="/Favicon_icon.svg" alt="Estudio de inteligencia artificial"/>
    <a href="#demo">
        <button class="boton boton-rojo btn-primary m-3" onclick="">Comenzar</button>
    </a>
</div>

<style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap');
    div {
        background-image: url('public/blob-haikei.svg');
        height: calc(50% + 50%);
        width: calc(50% + 50%);
        background-repeat: no-repeat;
        background-size: cover;
     }
     h1 {
        font-family: "Plus Jakarta Sans", sans-serif;
        font-weight: 800;
     }
</style>
