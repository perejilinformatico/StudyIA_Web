---
---
<div id="inicio" class="hero-wrapper">
  <div class="hero-bg">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
  </div>
  
  <div class="hero-content">
    <span class="hero-badge">
      <span class="badge-dot"></span>
      Powered by IA
    </span>
    
    <h1 class="hero-title">
      Study<span class="title-accent">IA</span>
    </h1>
    
    <p class="hero-subtitle">
      Tu asistente de estudio inteligente. <br>
      <span class="subtitle-typed" id="typed-text"></span><span class="cursor" id="cursor">|</span>
    </p>
    
    <div class="hero-actions">
      <a href="#demo" class="boton boton-rojo btn-hero">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="5 3 19 12 5 21 5 3"/>
        </svg>
        Comenzar Ahora
      </a>
      <a href="#informacion" class="boton boton-outline">
        Saber Más
      </a>
    </div>
    
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-number">+500</span>
        <span class="stat-label">Estudiantes</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">24/7</span>
        <span class="stat-label">Disponible</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-number">100%</span>
        <span class="stat-label">Gratuito</span>
      </div>
    </div>
  </div>
  
  <div class="hero-image">
    <div class="floating-card card-1">
      <div class="card-icon">⚡</div>
      <span>Respuestas instantáneas</span>
    </div>
    <div class="floating-card card-2">
      <div class="card-icon">🧠</div>
      <span>Explicaciones claras</span>
    </div>
    <div class="floating-card card-3">
      <div class="card-icon">🚀</div>
      <span>Estudia más rápido</span>
    </div>
  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap');
  
  .hero-wrapper {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    gap: 60px;
    overflow: hidden;
  }
  
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }
  
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.6;
    animation: float 20s ease-in-out infinite;
  }
  
  .blob-1 {
    width: 500px;
    height: 500px;
    background: linear-gradient(135deg, rgba(216,64,64,0.3), rgba(255,107,107,0.2));
    top: -150px;
    right: -100px;
    animation-delay: 0s;
  }
  
  .blob-2 {
    width: 400px;
    height: 400px;
    background: linear-gradient(135deg, rgba(255,107,107,0.2), rgba(255,183,77,0.15));
    bottom: -100px;
    left: -50px;
    animation-delay: -7s;
  }
  
  .blob-3 {
    width: 350px;
    height: 350px;
    background: linear-gradient(135deg, rgba(78,205,196,0.15), rgba(108,92,231,0.15));
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: -14s;
  }
  
  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(30px, -30px) scale(1.05); }
    50% { transform: translate(-20px, 20px) scale(0.95); }
    75% { transform: translate(20px, 10px) scale(1.02); }
  }
  
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 600px;
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 18px;
    background: rgba(216, 64, 64, 0.1);
    border: 1px solid rgba(216, 64, 64, 0.2);
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #D84040;
    margin-bottom: 24px;
    animation: fadeInUp 0.6s ease-out;
  }
  
  .badge-dot {
    width: 8px;
    height: 8px;
    background: #D84040;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }
  
  .hero-title {
    font-family: "Plus Jakarta Sans", sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 10vw, 5.5rem);
    line-height: 1.1;
    margin: 0 0 20px 0;
    color: #2B2A2A;
    animation: fadeInUp 0.6s ease-out 0.1s both;
  }
  
  .title-accent {
    background: linear-gradient(135deg, #D84040, #FF6B6B, #FFB74D);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-subtitle {
    font-size: 1.25rem;
    color: #525252;
    margin: 0 0 36px 0;
    line-height: 1.7;
    animation: fadeInUp 0.6s ease-out 0.2s both;
  }
  
  .subtitle-typed {
    color: #D84040;
    font-weight: 600;
  }
  
  .cursor {
    color: #D84040;
    font-weight: 300;
    animation: blink 0.8s ease-in-out infinite;
  }
  
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 40px;
    animation: fadeInUp 0.6s ease-out 0.3s both;
  }
  
  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 32px;
    font-size: 1.05rem;
  }
  
  .boton-outline {
    position: relative;
    padding: 14px 32px;
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 700;
    border-radius: 16px;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    outline: none;
    font-family: 'Segoe UI', 'Trebuchet MS', -apple-system, BlinkMacSystemFont, sans-serif;
    letter-spacing: 0.5px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    background: transparent;
    color: #D84040;
    border: 2px solid rgba(216, 64, 64, 0.3);
  }
  
  .boton-outline:hover {
    background: rgba(216, 64, 64, 0.05);
    border-color: #D84040;
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(216, 64, 64, 0.15);
  }
  
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    animation: fadeInUp 0.6s ease-out 0.4s both;
  }
  
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }
  
  .stat-number {
    font-size: 1.5rem;
    font-weight: 800;
    color: #2B2A2A;
    font-family: "Plus Jakarta Sans", sans-serif;
  }
  
  .stat-label {
    font-size: 0.8rem;
    color: #737373;
    font-weight: 500;
  }
  
  .stat-divider {
    width: 1px;
    height: 36px;
    background: #e5e5e5;
  }
  
  .hero-image {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 16px;
    animation: fadeInRight 0.8s ease-out 0.3s both;
  }
  
  .floating-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 20px;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
    font-weight: 600;
    color: #2B2A2A;
    font-size: 0.95rem;
    animation: floatCard 6s ease-in-out infinite;
  }
  
  .card-icon {
    font-size: 1.5rem;
  }
  
  .card-1 { animation-delay: 0s; }
  .card-2 { animation-delay: -2s; }
  .card-3 { animation-delay: -4s; }
  
  @keyframes floatCard {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-8px) rotate(0.5deg); }
    50% { transform: translateY(-4px) rotate(-0.5deg); }
    75% { transform: translateY(-10px) rotate(0.3deg); }
  }
  
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(40px); }
    to { opacity: 1; transform: translateX(0); }
  }
  
  @media (max-width: 1024px) {
    .hero-wrapper {
      flex-direction: column;
      text-align: center;
      min-height: auto;
      padding: 20px 20px 60px;
    }
    
    .hero-image {
      display: none;
    }
    
    .hero-actions {
      justify-content: center;
    }
    
    .hero-stats {
      flex-wrap: wrap;
    }
  }
  
  @media (max-width: 480px) {
    .hero-title {
      font-size: 2.8rem;
    }
    
    .hero-subtitle {
      font-size: 1.1rem;
    }
    
    .hero-stats {
      gap: 16px;
    }
    
    .stat-divider {
      display: none;
    }
  }
</style>

<script is:inline>
  const phrases = [
    "Transforma horas de estudio en minutos.",
    "Aprende cualquier tema con IA.",
    "Tu compañero inteligente de estudio.",
    "Explicaciones claras y adaptadas a vos."
  ];
  
  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const typedElement = document.getElementById("typed-text");
  
  function typeEffect() {
    const currentPhrase = phrases[phraseIndex];
    
    if (isDeleting) {
      typedElement.textContent = currentPhrase.substring(0, charIndex - 1);
      charIndex--;
    } else {
      typedElement.textContent = currentPhrase.substring(0, charIndex + 1);
      charIndex++;
    }
    
    let typeSpeed = isDeleting ? 30 : 60;
    
    if (!isDeleting && charIndex === currentPhrase.length) {
      typeSpeed = 2500;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      phraseIndex = (phraseIndex + 1) % phrases.length;
      typeSpeed = 400;
    }
    
    setTimeout(typeEffect, typeSpeed);
  }
  
  typeEffect();
</script>